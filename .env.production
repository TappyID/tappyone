# Configuração de Produção - Digital Ocean Droplet

# Database - Neon PostgreSQL
DATABASE_URL=postgresql://username:password@ep-xxx.neon.tech/dbname?sslmode=require

# JWT Secret - Gerar uma chave forte
JWT_SECRET=your-super-secret-jwt-key-production-256-bits

# WAHA API Configuration
WHATSAPP_API_URL=http://waha:3000
WHATSAPP_API_TOKEN=your-production-waha-token

# URLs de Produção
BASE_URL=https://api.yourdomain.com
WEBHOOK_URL=https://api.yourdomain.com/api/webhooks/whatsapp

# Server Configuration
PORT=8080
NODE_ENV=production

# Email SMTP (opcional)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_USER=your-email@yourdomain.com
SMTP_PASS=your-email-password
SMTP_FROM=your-email@yourdomain.com

# DeepSeek AI (opcional)
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_API_URL=https://api.deepseek.com
